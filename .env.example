# Copy this file to .env for local overrides. Never commit .env.
VITE_API_BASE_URL=/api

# Backend settings use AIOS_<SECTION>__<FIELD>. Relative paths are resolved
# under D:\Rujay\ai-intelligence-os and cannot escape the repository/data roots.
AIOS_PATHS__DATA_ROOT=data
AIOS_PATHS__DATABASE_PATH=state/ai-intelligence-os.db
AIOS_PATHS__RAW_DOCUMENTS_ROOT=raw
AIOS_PATHS__PROCESSED_DOCUMENTS_ROOT=processed
AIOS_PATHS__QUARANTINE_ROOT=quarantine
AIOS_PATHS__TEMPORARY_ROOT=temporary

# SQLite is always local, WAL-backed and foreign-key enforced.
AIOS_DATABASE__JOURNAL_MODE=WAL
AIOS_DATABASE__FOREIGN_KEYS=true
AIOS_DATABASE__BUSY_TIMEOUT_MS=5000

# Bounded download and HTTP policy. M0.2 does not perform HTTP requests.
AIOS_DOWNLOADS__MAXIMUM_DOCUMENT_BYTES=52428800
AIOS_DOWNLOADS__CHUNK_BYTES=65536
AIOS_HTTP__CONNECT_TIMEOUT_SECONDS=10
AIOS_HTTP__READ_TIMEOUT_SECONDS=60
AIOS_HTTP__MAXIMUM_RETRIES=3
AIOS_HTTP__INITIAL_BACKOFF_SECONDS=1
AIOS_HTTP__MAXIMUM_BACKOFF_SECONDS=30

# Phase-one source enablement only; connectors are not implemented in M0.2.
AIOS_SOURCES__ARXIV_ENABLED=true
AIOS_SOURCES__OPENREVIEW_ENABLED=true
AIOS_SOURCES__GITHUB_ENRICHMENT_ENABLED=true
AIOS_SOURCES__METADATA_OVERLAP_HOURS=24
# AIOS_SOURCES__GITHUB_TOKEN=replace-with-an-environment-only-token

# Local model configuration only. Models remain on-demand and unloadable.
# M0.2 never downloads, loads, or calls these models.
AIOS_OLLAMA__BASE_URL=http://127.0.0.1:11434
AIOS_OLLAMA__REQUEST_TIMEOUT_SECONDS=300
AIOS_OLLAMA__ON_DEMAND_ONLY=true
AIOS_OLLAMA__UNLOAD_AFTER_GENERATION=true
AIOS_TOKEN_LIMITS__MAXIMUM_CONTEXT_TOKENS=12288
AIOS_TOKEN_LIMITS__MAXIMUM_OUTPUT_TOKENS=3000
AIOS_MODELS__SCOUT__MODEL=qwen3:4b
AIOS_MODELS__SCOUT__MAXIMUM_CONTEXT_TOKENS=8192
AIOS_MODELS__SCOUT__MAXIMUM_OUTPUT_TOKENS=1200
AIOS_MODELS__SCOUT__KEEP_ALIVE_SECONDS=0
AIOS_MODELS__ANALYST__MODEL=qwen3:8b
AIOS_MODELS__ANALYST__MAXIMUM_CONTEXT_TOKENS=12288
AIOS_MODELS__ANALYST__MAXIMUM_OUTPUT_TOKENS=3000
AIOS_MODELS__ANALYST__KEEP_ALIVE_SECONDS=0
AIOS_MODELS__EMBED__MODEL=embeddinggemma
AIOS_MODELS__EMBED__BATCH_SIZE=8
AIOS_MODELS__EMBED__KEEP_ALIVE_SECONDS=0

# Retention ceilings for later cleanup work; no cleanup runs in M0.2.
AIOS_RETENTION__RAW_PAYLOAD_DAYS=30
AIOS_RETENTION__TEMPORARY_FILE_HOURS=24
AIOS_RETENTION__FAILED_ARTIFACT_DAYS=30
AIOS_RETENTION__MAXIMUM_STORAGE_GIB=100

# Daily generation-count limits. M0.2 defines policy only; it does not schedule work.
AIOS_DAILY_WORK__MAXIMUM_FAST_BRIEFS=10
AIOS_DAILY_WORK__MAXIMUM_AUTOMATIC_DEEP_DIVES=2

# Hard resource policy for the 16 GB RAM / 8 GB VRAM target laptop.
AIOS_RESOURCES__NON_LLM_APPLICATION_RAM_MB=2048
AIOS_RESOURCES__NORMAL_PROJECT_RAM_MB=6144
AIOS_RESOURCES__ABSOLUTE_PROJECT_PEAK_RAM_MB=8192
AIOS_RESOURCES__WINDOWS_RESERVED_RAM_MB=8192
AIOS_RESOURCES__VRAM_TARGET_MB=6656
AIOS_RESOURCES__SOURCE_DOWNLOAD_CONCURRENCY=3
AIOS_RESOURCES__LLM_GENERATION_CONCURRENCY=1
